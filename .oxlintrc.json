{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "node"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-await-in-loop": "off"
  },
  "env": {
    "builtin": true,
    "node": true,
    "es2024": true
  },
  "globals": {},
  "ignorePatterns": [
    "dist/",
    "node_modules/"
  ]
}
