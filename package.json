{
  "name": "fusewire-js",
  "version": "0.1.0",
  "description": "Fusewire JS Express application",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "lint": "oxlint src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "test": "node --test test/**/*.test.js",
    "jsdoc-check": "eslint src/"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "eslint-plugin-jsdoc": "^62.8.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0"
  }
}
